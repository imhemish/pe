{
    "app-id" : "io.github.imhemish.pe",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "43",
    "sdk" : "org.gnome.Sdk",
    "command" : "pe",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=dri",
        "--socket=wayland",
        "--system-talk-name=org.freedesktop.ModemManager1"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
        {
            "name" : "pe",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "path" : "/home/cat/github/pe"
                }
            ]
        },
        
        {
             "name": "dbus-python",
             "builddir": true,
             "buildsystem" : "meson",
             "sources" : [
             	{
             	    "type" : "git",
             	    "url": "https://github.com/freedesktop/dbus-python.git",
             	    "tag": "dbus-python-1.3.2"
             	}
             ]
        }
        
        
    ]
}
