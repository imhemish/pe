using Gtk 4.0;
using Adw 1;

template SuccessView : Gtk.Box {
    child: Gtk.Box {
        orientation: vertical;
        vexpand: true;

        Adw.HeaderBar {
            centering-policy: strict;
            name: "UPI";

            Gtk.Button {
              icon-name: "go-previous-symbolic";
              action-name: "win.go_back_to_main_view";
            }

            [end]
            .MenuButton {}
        }

              
        Gtk.Box {
            vexpand: true;
            hexpand: true;
            halign: center;

            Adw.StatusPage success_view_status {
                icon-name: "emblem-default-symbolic";
                title: "Success";
            }
        }
    };

}